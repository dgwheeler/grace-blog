---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About" description="About me" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
			}
			main p {
				margin-bottom: 1em;
				line-height: 1.7;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
		</main>
		<Footer />
	</body>
</html>
