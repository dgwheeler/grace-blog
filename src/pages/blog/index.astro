---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { CATEGORIES } from '../../categories';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => (a.data.order ?? 9999) - (b.data.order ?? 9999),
);

// Normalize slugs: treat hyphens and underscores as equivalent
const norm = (s: string) => s.replace(/[-_]/g, '-');

// Discover categories from posts, ordered by CATEGORIES config
const usedSlugs = [...new Set(allPosts.map(p => norm(p.data.category)).filter(Boolean))];
const orderedCategories = CATEGORIES.length > 0
	? CATEGORIES.filter(c => usedSlugs.includes(norm(c.slug)))
	: usedSlugs.map(slug => ({ slug, label: slug, subtitle: '' }));

const postsByCategory = Object.fromEntries(
	orderedCategories.map(c => [c.slug, allPosts.filter(p => norm(p.data.category) === norm(c.slug))])
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Essays — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				padding: 2.5rem 0 0;
			}
			.page-header h1 {
				font-family: var(--font-display);
				font-size: 3.2rem;
				font-weight: 700;
				margin-bottom: 0.3rem;
			}
			.page-header .tagline {
				font-family: var(--font-serif);
				font-style: italic;
				color: var(--color-text-light);
				font-size: 1.15rem;
				margin-top: 0.3rem;
			}
			.section-line {
				width: 100%;
				height: 1px;
				background: var(--color-border-light);
				margin: 1.5rem 0;
			}
			.category-section {
				margin-bottom: 0;
			}
			.category-section h2 {
				font-family: var(--font-display);
				font-size: 1.4rem;
				font-weight: 700;
				color: var(--color-text);
				margin-bottom: 0.8rem;
			}
			.essay-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.essay-list li {
				border-bottom: 1px solid var(--color-border-light);
				padding: 0.7rem 0;
			}
			.essay-list li:last-child {
				border-bottom: none;
			}
			.essay-list li::before {
				content: '·';
				margin-right: 0.6rem;
				color: var(--color-text-light);
			}
			.essay-list a {
				font-family: var(--font-serif);
				font-size: 1rem;
				text-decoration: none;
				color: var(--color-text);
				transition: color 0.2s;
			}
			.essay-list a:hover {
				color: var(--color-accent-dark);
			}
			.pagination {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 0.8rem;
				font-family: var(--font-serif);
				font-size: 0.88rem;
			}
			.pagination a {
				color: var(--color-text);
				text-decoration: none;
				cursor: pointer;
				transition: color 0.2s;
			}
			.pagination a:hover {
				color: var(--color-accent-dark);
			}
			.pagination a.disabled {
				visibility: hidden;
			}
			.empty {
				color: var(--color-text-light);
				font-style: italic;
				font-size: 0.9rem;
				padding: 1rem 0;
			}
			@media (max-width: 600px) {
				.page-header h1 {
					font-size: 2.4rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>Essays</h1>
				<p class="tagline">{SITE_DESCRIPTION}</p>
			</div>
			<div class="section-line"></div>

			{orderedCategories.map(cat => (
				<section class="category-section" data-category={cat.slug}>
					<h2>{cat.label}</h2>
					{(postsByCategory[cat.slug] || []).length > 0 ? (
						<>
							<ul class="essay-list" data-page-size="6">
								{(postsByCategory[cat.slug] || []).map(post => (
									<li>
										<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									</li>
								))}
							</ul>
							{(postsByCategory[cat.slug] || []).length > 6 && (
								<div class="pagination">
									<a class="page-prev disabled">← Previous</a>
									<a class="page-next">Next →</a>
								</div>
							)}
						</>
					) : (
						<p class="empty">Essays coming soon.</p>
					)}
					<div class="section-line"></div>
				</section>
			))}
		</main>
		<Footer />

		<script>
			document.querySelectorAll('.essay-list[data-page-size]').forEach(list => {
				const pageSize = parseInt(list.getAttribute('data-page-size') || '6');
				const items = Array.from(list.children);
				if (items.length <= pageSize) return;

				let page = 0;
				const totalPages = Math.ceil(items.length / pageSize);
				const section = list.closest('section');
				const prevBtn = section?.querySelector('.page-prev');
				const nextBtn = section?.querySelector('.page-next');

				function render() {
					const start = page * pageSize;
					const end = start + pageSize;
					items.forEach((item, i) => {
						(item as HTMLElement).style.display = (i >= start && i < end) ? '' : 'none';
					});
					if (prevBtn) {
						prevBtn.classList.toggle('disabled', page === 0);
					}
					if (nextBtn) {
						nextBtn.classList.toggle('disabled', page >= totalPages - 1);
					}
				}

				prevBtn?.addEventListener('click', (e) => {
					e.preventDefault();
					if (page > 0) { page--; render(); }
				});
				nextBtn?.addEventListener('click', (e) => {
					e.preventDefault();
					if (page < totalPages - 1) { page++; render(); }
				});

				render();
			});
		</script>
	</body>
</html>
