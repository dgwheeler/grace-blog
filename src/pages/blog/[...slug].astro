---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	// Normalize slugs: treat hyphens and underscores as equivalent
	const norm = (s: string) => s.replace(/[-_]/g, '-');

	// Group posts by category, sorted by order within each category
	const postsByCategory: Record<string, typeof posts> = {};
	for (const post of posts) {
		const cat = norm(post.data.category || 'uncategorized');
		if (!postsByCategory[cat]) postsByCategory[cat] = [];
		postsByCategory[cat].push(post);
	}
	for (const cat of Object.keys(postsByCategory)) {
		postsByCategory[cat].sort((a, b) => (a.data.order ?? 9999) - (b.data.order ?? 9999));
	}

	return posts.map((post) => {
		const cat = norm(post.data.category || 'uncategorized');
		const categoryPosts = postsByCategory[cat];
		const index = categoryPosts.findIndex(p => p.id === post.id);
		const prev = index > 0 ? categoryPosts[index - 1] : null;
		const next = index < categoryPosts.length - 1 ? categoryPosts[index + 1] : null;
		return {
			params: { slug: post.id },
			props: {
				post,
				prevPost: prev ? { title: prev.data.title, slug: prev.id } : null,
				nextPost: next ? { title: next.data.title, slug: next.id } : null,
			},
		};
	});
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prevPost={prevPost} nextPost={nextPost}>
	<Content />
</BlogPost>
