---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const afterPosts = allPosts.filter(p => p.data.category === 'after-two-thirty');
const beforePosts = allPosts.filter(p => p.data.category === 'before-two-thirty');
const featured = allPosts[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 2.5rem 0 1.5rem;
			}
			.hero h1 {
				font-family: var(--font-display);
				font-size: 3.2rem;
				font-weight: 700;
				color: var(--color-text);
				letter-spacing: -0.01em;
				margin-bottom: 0.3rem;
			}
			.hero-line {
				width: 200px;
				height: 2px;
				background: var(--color-accent);
				margin: 0.4rem auto;
			}
			.hero .tagline {
				font-family: var(--font-serif);
				font-style: italic;
				color: var(--color-text-light);
				font-size: 1.15rem;
				margin-top: 0.3rem;
			}
			.opening {
				max-width: 580px;
				margin: 0 auto;
				padding: 0.5rem 0 1.5rem;
				text-align: center;
			}
			.opening p {
				font-size: 1rem;
				line-height: 1.9;
				color: var(--color-text);
				margin-bottom: 1rem;
			}
			.begin-reading {
				padding: 1.5rem 0;
				border-top: 1px solid var(--color-border-light);
				border-bottom: 1px solid var(--color-border-light);
				margin-bottom: 1.5rem;
			}
			.begin-reading .label {
				font-family: var(--font-serif);
				font-style: italic;
				font-size: 1rem;
				color: var(--color-text-light);
				margin-bottom: 0.8rem;
			}
			.featured-content {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				align-items: flex-start;
			}
			.featured-text h2 {
				font-family: var(--font-display);
				font-size: 1.6rem;
				font-weight: 700;
				margin-bottom: 0.5rem;
			}
			.featured-text .excerpt {
				font-size: 0.95rem;
				color: var(--color-text-light);
				line-height: 1.7;
				margin-bottom: 1.2rem;
			}
			.featured-image :global(img) {
				width: 100%;
				height: auto;
				border-radius: 4px;
			}
			.featured-image .caption {
				font-family: var(--font-sans);
				font-size: 0.75rem;
				color: var(--color-text-light);
				text-align: right;
				margin-top: 0.4rem;
			}
			.category-columns {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem;
				margin: 0 0 1.5rem;
			}
			.category-column h2 {
				font-family: var(--font-display);
				font-size: 1.3rem;
				font-weight: 700;
				margin-bottom: 0.2rem;
			}
			.category-column .subtitle {
				font-family: var(--font-serif);
				font-style: italic;
				font-size: 0.88rem;
				color: var(--color-text-light);
				margin-bottom: 1.2rem;
			}
			.essay-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.essay-list li {
				border-bottom: 1px solid var(--color-border-light);
				padding: 0.7rem 0;
			}
			.essay-list li:last-child {
				border-bottom: none;
			}
			.essay-list a {
				text-decoration: none;
				color: inherit;
			}
			.essay-list a:hover h3 {
				color: var(--color-accent-dark);
			}
			.essay-list h3 {
				font-family: var(--font-display);
				font-size: 1rem;
				font-weight: 600;
				margin-bottom: 0.15rem;
				transition: color 0.2s;
			}
			.essay-list .date {
				font-family: var(--font-sans);
				font-size: 0.7rem;
				color: var(--color-text-light);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.empty {
				color: var(--color-text-light);
				font-style: italic;
				font-size: 0.9rem;
				padding: 0.5rem 0;
			}
			.dedication {
				text-align: center;
				padding: 1.5rem 0 0.5rem;
				font-family: var(--font-script);
				font-size: 4rem;
				color: var(--color-text);
			}
			.dedication .heart {
				font-size: 1.4rem;
				margin-top: 0.3rem;
				color: var(--color-accent);
			}
			@media (max-width: 600px) {
				.hero h1 {
					font-size: 2.4rem;
				}
				.featured-content {
					grid-template-columns: 1fr;
				}
				.category-columns {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.dedication {
					font-size: 3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>{SITE_TITLE}</h1>
				<div class="hero-line"></div>
				<p class="tagline">{SITE_DESCRIPTION}</p>
			</div>

			<div class="opening">
				<p>Every afternoon at 2:30, I stand at the school gate and wait for my daughters to walk out.</p>
				<p>They experience the world a little differently, and raising them has taught me to notice things I might once have missed.</p>
				<p>These essays are small moments from our life — the waiting, the worrying, the laughter — and the quiet learning that comes <em>after two-thirty.</em></p>
			</div>

			{featured && (
				<div class="begin-reading">
					<p class="label">Begin Reading</p>
					<div class="featured-content">
						<div class="featured-text">
							<h2>{featured.data.title}</h2>
							<p class="excerpt">{featured.data.description}</p>
							<a class="btn-read" href={`/blog/${featured.id}/`}>Read Essay →</a>
						</div>
						{featured.data.heroImage ? (
							<div class="featured-image">
								<Image src={featured.data.heroImage} alt={featured.data.title} />
								<p class="caption">Drawing by Vicky</p>
							</div>
						) : (
							<div class="featured-image"></div>
						)}
					</div>
				</div>
			)}

			<div class="category-columns">
				<div class="category-column">
					<h2>After Two Thirty</h2>
					<p class="subtitle">Stories from the school gate</p>
					<ul class="essay-list">
						{afterPosts.map(post => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
						{afterPosts.length === 0 && <li><p class="empty">Essays coming soon.</p></li>}
					</ul>
				</div>
				<div class="category-column">
					<h2>Before Two Thirty</h2>
					<p class="subtitle">The world children are growing into</p>
					<ul class="essay-list">
						{beforePosts.map(post => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3>{post.data.title}</h3>
									<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								</a>
							</li>
						))}
						{beforePosts.length === 0 && <li><p class="empty">Essays coming soon.</p></li>}
					</ul>
				</div>
			</div>
		</main>
		<Footer>
			<div class="dedication">
				<p>For Vicky and Sydney</p>
				<div class="heart">&#x1F331;</div>
			</div>
		</Footer>
	</body>
</html>
