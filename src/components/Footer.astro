---
const today = new Date();
---

<footer>
	<div class="footer-nav">
		<a href="/">Home</a>
		<span class="footer-sep">|</span>
		<a href="/blog">Essays</a>
		<span class="footer-sep">|</span>
		<a href="/why-i-write">Why I Write</a>
		<span class="footer-sep">|</span>
		<a href="/about">About</a>
	</div>
	<slot />
</footer>
<style>
	footer {
		border-top: 1px solid var(--color-border);
		padding: 2rem 2rem 2.5rem;
		text-align: center;
		font-family: var(--font-serif);
		font-size: 0.88rem;
		color: var(--color-text);
	}
	.footer-nav {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0;
		flex-wrap: wrap;
		margin-bottom: 1.8rem;
	}
	.footer-nav :global(a) {
		font-family: var(--font-serif);
		font-size: 0.88rem;
		color: var(--color-text);
		text-decoration: none;
		padding: 0 1rem;
	}
	.footer-nav :global(a:hover) {
		color: var(--color-accent-dark);
	}
	.footer-nav :global(.footer-sep) {
		color: var(--color-border);
		font-size: 0.9rem;
		user-select: none;
	}
	.footer-nav :global(.footer-text) {
		font-family: var(--font-serif);
		font-size: 0.88rem;
		color: var(--color-text);
		padding: 0 1rem;
	}
	.dedication {
		text-align: center;
		padding: 1.5rem 0 0.5rem;
		font-family: var(--font-script);
		color: var(--color-text);
	}
	.dedication p {
		font-size: 2rem;
		margin-bottom: 0;
	}
	.dedication .heart {
		font-size: 1.4rem;
		margin-top: 0.3rem;
		color: var(--color-accent);
	}
	@media (max-width: 600px) {
		.footer-nav :global(a) {
			padding: 0 0.6rem;
			font-size: 0.8rem;
		}
		.dedication p {
			font-size: 2.2rem;
		}
	}
</style>
