---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCategoryLabel } from '../categories';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: any;
	category?: string;
	prevPost?: { title: string; slug: string };
	nextPost?: { title: string; slug: string };
}

const { title, description, pubDate, updatedDate, heroImage, category, prevPost, nextPost } = Astro.props;

const categoryLabel = category ? getCategoryLabel(category) : '';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.post-header {
				text-align: center;
				margin-bottom: 2rem;
			}
			.category-label {
				font-family: var(--font-sans);
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.25em;
				color: var(--color-text-light);
				margin-bottom: 0.8rem;
			}
			.page-title {
				font-family: var(--font-display);
				font-size: 2.2rem;
				font-weight: 400;
				margin-bottom: 1.5rem;
				letter-spacing: -0.01em;
			}
			.hero-image {
				width: 100%;
				max-height: 360px;
				object-fit: cover;
				display: block;
				margin: 0 auto 2rem;
			}
			.prose {
				max-width: 620px;
				width: 100%;
				margin: 0 auto;
			}
			.essay-nav {
				border-top: 1px solid var(--color-border-light);
				margin-top: 3rem;
				padding-top: 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.essay-nav a {
				text-decoration: none;
				color: var(--color-text);
				font-family: var(--font-serif);
				font-size: 0.9rem;
				transition: color 0.2s;
			}
			.essay-nav a:hover {
				color: var(--color-accent-dark);
			}
			.essay-nav .next {
				margin-left: auto;
			}
			@media (max-width: 600px) {
				.page-title {
					font-size: 1.8rem;
				}
				.hero-image {
					max-height: 260px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="post-header">
						{categoryLabel && <p class="category-label">{categoryLabel}</p>}
						<h1 class="page-title">{title}</h1>
					</div>
					{heroImage && <img class="hero-image" src={heroImage.src || heroImage} alt={title} />}
					<slot />

					{(prevPost || nextPost) && (
						<nav class="essay-nav">
							{prevPost ? (
								<a href={`/blog/${prevPost.slug}/`}>← Previous Essay</a>
							) : <span />}
							{nextPost ? (
								<a href={`/blog/${nextPost.slug}/`} class="next">Next Essay →</a>
							) : <span />}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
