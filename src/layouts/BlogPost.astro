---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCategoryLabel } from '../categories';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: any;
	category?: string;
	prevPost?: { title: string; slug: string };
	nextPost?: { title: string; slug: string };
}

const { title, description, pubDate, updatedDate, heroImage, category, prevPost, nextPost } = Astro.props;

const categoryLabel = category ? getCategoryLabel(category) : '';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				max-width: 620px;
				width: 100%;
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
				max-height: 360px;
				object-fit: cover;
				border-radius: 6px;
				margin-bottom: 2rem;
				display: block;
			}
			.category-label {
				font-family: var(--font-sans);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--color-accent);
				font-weight: 600;
				margin-bottom: 0.4rem;
			}
			.page-title {
				font-family: var(--font-display);
				font-size: 2.2rem;
				font-weight: 700;
				margin-bottom: 0.3rem;
				letter-spacing: -0.01em;
			}
			.date {
				font-family: var(--font-sans);
				font-size: 0.8rem;
				color: var(--color-text-light);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.last-updated-on {
				font-style: italic;
				text-transform: none;
			}
			.divider {
				width: 100%;
				height: 1px;
				background: var(--color-border);
				margin: 1rem 0 2rem;
			}
			.essay-nav {
				border-top: 1px solid var(--color-border-light);
				margin-top: 3rem;
				padding-top: 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				gap: 2rem;
			}
			.essay-nav a {
				text-decoration: none;
				color: inherit;
				max-width: 45%;
			}
			.essay-nav a:hover .nav-title {
				color: var(--color-accent-dark);
			}
			.essay-nav .nav-label {
				font-family: var(--font-sans);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-text-light);
				display: block;
				margin-bottom: 0.25rem;
			}
			.essay-nav .nav-title {
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 600;
				transition: color 0.2s;
			}
			.essay-nav .next {
				text-align: right;
				margin-left: auto;
			}
			@media (max-width: 600px) {
				.page-title {
					font-size: 1.8rem;
				}
				.hero-image {
					max-height: 260px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					{heroImage && <img class="hero-image" src={heroImage.src || heroImage} alt={title} />}
					{categoryLabel && <p class="category-label">{categoryLabel}</p>}
					<h1 class="page-title">{title}</h1>
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									&middot; Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<div class="divider"></div>
					<slot />

					{(prevPost || nextPost) && (
						<nav class="essay-nav">
							{prevPost ? (
								<a href={`/blog/${prevPost.slug}/`}>
									<span class="nav-label">← Previous</span>
									<span class="nav-title">{prevPost.title}</span>
								</a>
							) : <span />}
							{nextPost ? (
								<a href={`/blog/${nextPost.slug}/`} class="next">
									<span class="nav-label">Next →</span>
									<span class="nav-title">{nextPost.title}</span>
								</a>
							) : <span />}
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
